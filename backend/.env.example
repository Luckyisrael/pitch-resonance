# TxLINE API (txline-dev.txodds.com)
# Get credentials from https://txline.txodds.com/documentation/quickstart
TXODDS_API_BASE=https://txline-dev.txodds.com/api
TXODDS_JWT=your_jwt_token_here
TXODDS_API_TOKEN=your_api_token_here

# Solana (devnet)
SOLANA_RPC=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# JWT secret for auth endpoint (required)
JWT_SECRET=change-this-to-a-random-secret

# Server
PORT=4000

# CORS origin (comma-separated or *)
FRONTEND_URL=*
